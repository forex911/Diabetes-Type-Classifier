# DVC ignore file
# Patterns listed here will be ignored by DVC

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.env
.venv
env/
venv/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
